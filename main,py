import requests
import urllib3
import time
import csv
import json
import os
from datetime import datetime, UTC

urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

BASE_URL = "https://127.0.0.1:2999/liveclientdata"
POLL_INTERVAL = 5

session = requests.Session()
session.verify = False

timeline_rows = []
events_seen = set()
events = []

last_game_time = None

match_info = {}
players_metadata = []

debug_game_detected = False

# Events the API actually fires reliably on Summoner's Rift.
# Dragon/Baron/Herald kills are NOT exposed by this API — they are absent
# from the /eventdata endpoint entirely. Turret and inhibitor kills do fire.
KNOWN_WORKING_EVENTS = {
    "GameStart",
    "MinionsSpawning",
    "FirstBlood",
    "ChampionKill",
    "Multikill",
    "Ace",
    "TurretKilled",
    "InhibKilled",
    "InhibRespawningSoon",
    "InhibRespawned",
    "GameEnd",
}


def get(endpoint):
    try:
        r = session.get(f"{BASE_URL}/{endpoint}", timeout=2)
        if r.status_code == 200:
            return r.json()
    except:
        return None


def wait_for_game():
    print("Waiting for game...")
    while True:
        data = get("gamestats")
        if data:
            print("Game detected")
            return
        time.sleep(2)


def collect_metadata():
    global debug_game_detected
    global match_info
    global players_metadata

    data = get("allgamedata")

    if not data:
        return

    if not debug_game_detected:
        map_name = data.get("gameData", {}).get("mapName", "Unknown")
        players = [p.get("summonerName", "Unknown") for p in data.get("allPlayers", [])]

        print("\n=== GAME DETECTED ===")
        print(f"Map: {map_name}")
        print(f"Players detected ({len(players)}):")
        for p in players:
            print(f" - {p}")
        print("=====================\n")

        debug_game_detected = True

    game_data = data.get("gameData", {})

    match_info = {
        "map": game_data.get("mapName"),
        "mode": game_data.get("gameMode"),
        # mapTerrain reflects the elemental rift type (Infernal, Ocean, Mountain, Hextech, Chemtech, Default)
        "map_terrain": game_data.get("mapTerrain"),
        "start_time": datetime.now(UTC).isoformat(),
        # winner is populated at game end via determine_winner()
        "winner": None,
    }

    players_metadata = []

    for p in data.get("allPlayers", []):
        runes = p.get("runes", {})
        spells = p.get("summonerSpells", {})

        players_metadata.append({
            "summonerName": p.get("summonerName"),
            "riotId": p.get("riotId"),
            "team": p.get("team"),
            "champion": p.get("championName"),
            "is_bot": p.get("isBot"),
            # position is assigned by the client (TOP/JUNGLE/MIDDLE/BOTTOM/UTILITY)
            # may be empty string early in the game before roles are detected
            "position": p.get("position"),
            # runes: only keystone + primary/secondary trees are exposed for all players
            # full rune pages are only available for the active (local) player
            "keystone": runes.get("keystone", {}).get("displayName"),
            "primary_rune_tree": runes.get("primaryRuneTree", {}).get("displayName"),
            "secondary_rune_tree": runes.get("secondaryRuneTree", {}).get("displayName"),
            # summoner spells
            "summoner_spell_1": spells.get("summonerSpellOne", {}).get("displayName"),
            "summoner_spell_2": spells.get("summonerSpellTwo", {}).get("displayName"),
        })


def collect_snapshot():
    global last_game_time

    data = get("allgamedata")

    if not data:
        return

    game_time = data.get("gameData", {}).get("gameTime", 0)

    # If gameTime hasn't advanced the game is paused — skip to avoid duplicate rows
    if game_time == last_game_time:
        return

    last_game_time = game_time

    for p in data.get("allPlayers", []):
        scores = p.get("scores", {})

        # Capture full item data per slot: id and count allow precise build tracking
        # (component rushes, stacking items like Mejai's, build order over time).
        # Stored as JSON so the CSV remains a single column but is still parseable.
        items = []
        for item in p.get("items", []):
            items.append({
                "id": item.get("itemID"),
                "name": item.get("displayName"),
                "slot": item.get("slot"),
                "count": item.get("count"),
            })

        timeline_rows.append({
            "timestamp": game_time,
            "player": p.get("summonerName"),
            "team": p.get("team"),
            "champion": p.get("championName"),
            "position": p.get("position"),

            "level": p.get("level"),
            # isDead and respawnTimer are useful for correlating deaths with objective timings
            "is_dead": p.get("isDead"),
            "respawn_timer": p.get("respawnTimer"),

            "kills": scores.get("kills"),
            "deaths": scores.get("deaths"),
            "assists": scores.get("assists"),
            "cs": scores.get("creepScore"),
            # wardScore accumulates vision score over the game
            "ward_score": scores.get("wardScore"),

            # NOTE: currentGold is only available for the active (local) player via
            # /activeplayer. It is NOT present in allPlayers. In spectator mode this
            # field will always be absent here.

            "items": json.dumps(items)
        })


def collect_events():
    data = get("eventdata")

    if not data:
        return

    for e in data.get("Events", []):
        key = (e.get("EventName"), e.get("EventTime"), e.get("KillerName"))

        if key not in events_seen:
            events_seen.add(key)
            events.append(e)


def determine_winner():
    """
    Extract the winning team from collected events.

    Strategy 1 — GameEnd event with a Recipient field.
      The Live Client Data API fires a GameEnd event. Community reports suggest
      it may carry a 'Recipient' field with the winning team. We attempt this first
      and log all GameEnd fields so the format can be verified and improved.

    Strategy 2 — Infer from the last turret destroyed.
      The nexus is the last structure destroyed before GameEnd. The final
      TurretKilled event's turret name encodes the owning team (TChaos/TOrder),
      so the destroying team (opposite) is the winner.

    Returns 'ORDER', 'CHAOS', or None if undetermined.
    """
    game_end_events = [e for e in events if e.get("EventName") == "GameEnd"]

    # Strategy 1: inspect GameEnd fields
    if game_end_events:
        ge = game_end_events[-1]

        # Log everything so we can see exactly what the API returns
        print(f"[GameEnd fields]: {list(ge.keys())}")
        print(f"[GameEnd data]:   {ge}")

        recipient = ge.get("Recipient")
        if recipient in ("ORDER", "CHAOS"):
            print(f"[Winner via GameEnd.Recipient]: {recipient}")
            return recipient

        # Some versions may use 'Result' or other keys — log them for future use
        for key in ("Result", "Winner", "WinningTeam"):
            val = ge.get(key)
            if val:
                print(f"[GameEnd.{key}]: {val} (not used yet — update determine_winner if reliable)")

    # Strategy 2: last turret killed = nexus, infer winner from turret ownership
    turret_events = [e for e in events if e.get("EventName") == "TurretKilled"]

    if turret_events:
        last_turret = turret_events[-1]
        turret_name = last_turret.get("TurretKilled", "")

        if "TChaos" in turret_name:
            print(f"[Winner via last turret ({turret_name})]: ORDER")
            return "ORDER"
        elif "TOrder" in turret_name:
            print(f"[Winner via last turret ({turret_name})]: CHAOS")
            return "CHAOS"

    print("[Winner]: Could not determine — no GameEnd fields or turret name matched.")
    return None


def game_running():
    return get("gamestats") is not None


def create_match_folder():
    timestamp = datetime.now().strftime("%Y-%m-%d_%H-%M")
    folder = f"scrim_{timestamp}"
    os.makedirs(folder, exist_ok=True)
    return folder


def export_timeline(folder):
    file = os.path.join(folder, "player_timeline.csv")

    keys = [
        "timestamp",
        "player",
        "team",
        "champion",
        "position",
        "level",
        "is_dead",
        "respawn_timer",
        "kills",
        "deaths",
        "assists",
        "cs",
        "ward_score",
        "items"
    ]

    with open(file, "w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=keys)
        writer.writeheader()
        writer.writerows(timeline_rows)

    print("Saved timeline")


def export_events(folder):
    if not events:
        return

    file = os.path.join(folder, "events.csv")

    keys = set()
    for e in events:
        keys.update(e.keys())

    keys = sorted(keys)

    with open(file, "w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=keys, extrasaction="ignore")
        writer.writeheader()
        writer.writerows(events)

    print("Saved events")


def export_metadata(folder):
    data = {
        "match": match_info,
        "players": players_metadata
    }

    file = os.path.join(folder, "metadata.json")

    with open(file, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2)

    print("Saved metadata")


def run():
    wait_for_game()

    collect_metadata()

    print("Collecting match data...")

    while game_running():
        collect_snapshot()
        collect_events()
        time.sleep(POLL_INTERVAL)

    # Final flush — poll one last time immediately after the game ends.
    # The game loop exits when game_running() returns False, but the API may
    # still have a few events (including GameEnd) available for a brief window.
    # We attempt up to 3 quick polls to catch anything the loop missed.
    print("Game ended — flushing final events...")
    for _ in range(3):
        collect_events()
        import time as _t; _t.sleep(0.5)

    print("Determining winner...")

    winner = determine_winner()
    match_info["winner"] = winner

    if winner:
        print(f"Winner: {winner}")
    else:
        print("Winner could not be determined automatically.")

    folder = create_match_folder()

    export_timeline(folder)
    export_events(folder)
    export_metadata(folder)

    print("Match data saved in:", folder)


if __name__ == "__main__":
    run()