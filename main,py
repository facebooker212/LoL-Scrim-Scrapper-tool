import requests
import urllib3
import time
import csv
import json
import os
from datetime import datetime, UTC

urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

BASE_URL = "https://127.0.0.1:2999/liveclientdata"
POLL_INTERVAL = 5

session = requests.Session()
session.verify = False

timeline_rows = []
events_seen = set()
events = []

match_info = {}
players_metadata = []

debug_game_detected = False

# Events the API actually fires reliably on Summoner's Rift.
# Dragon/Baron/Herald kills are NOT exposed by this API - they are absent
# from the /eventdata endpoint entirely. Turret and inhibitor kills do fire.
KNOWN_WORKING_EVENTS = {
    "GameStart",
    "MinionsSpawning",
    "FirstBlood",
    "ChampionKill",
    "Multikill",
    "Ace",
    "TurretKilled",
    "InhibKilled",
    "InhibRespawningSoon",
    "InhibRespawned",
    "GameEnd",
}


def get(endpoint):
    try:
        r = session.get(f"{BASE_URL}/{endpoint}", timeout=2)
        if r.status_code == 200:
            return r.json()
    except:
        return None


def wait_for_game():
    print("Waiting for game...")
    while True:
        data = get("gamestats")
        if data:
            print("Game detected")
            return
        time.sleep(2)


def collect_metadata():
    global debug_game_detected
    global match_info
    global players_metadata

    data = get("allgamedata")

    if not data:
        return

    if not debug_game_detected:

        map_name = data.get("gameData", {}).get("mapName", "Unknown")
        players = [p.get("summonerName", "Unknown") for p in data.get("allPlayers", [])]

        print("\n=== GAME DETECTED ===")
        print(f"Map: {map_name}")
        print(f"Players detected ({len(players)}):")

        for p in players:
            print(f" - {p}")

        print("=====================\n")

        debug_game_detected = True

    game_data = data.get("gameData", {})

    match_info = {
        "map": game_data.get("mapName"),
        "mode": game_data.get("gameMode"),
        # mapTerrain reflects the elemental rift type (Infernal, Ocean, Mountain, Hextech, Chemtech, Default)
        "map_terrain": game_data.get("mapTerrain"),
        "start_time": datetime.now(UTC).isoformat()
    }

    players_metadata = []

    for p in data.get("allPlayers", []):
        runes = p.get("runes", {})
        spells = p.get("summonerSpells", {})

        players_metadata.append({
            "summonerName": p.get("summonerName"),
            "riotId": p.get("riotId"),
            "team": p.get("team"),
            "champion": p.get("championName"),
            "is_bot": p.get("isBot"),
            # position is assigned by the client (TOP/JUNGLE/MIDDLE/BOTTOM/UTILITY)
            # may be empty string early in the game before roles are detected
            "position": p.get("position"),
            # runes: only keystone + primary/secondary trees are exposed for all players
            # full rune pages are only available for the active (local) player
            "keystone": runes.get("keystone", {}).get("displayName"),
            "primary_rune_tree": runes.get("primaryRuneTree", {}).get("displayName"),
            "secondary_rune_tree": runes.get("secondaryRuneTree", {}).get("displayName"),
            # summoner spells
            "summoner_spell_1": spells.get("summonerSpellOne", {}).get("displayName"),
            "summoner_spell_2": spells.get("summonerSpellTwo", {}).get("displayName"),
        })


def collect_snapshot():
    data = get("allgamedata")

    if not data:
        return

    game_time = data.get("gameData", {}).get("gameTime", 0)

    for p in data.get("allPlayers", []):

        scores = p.get("scores", {})

        # Capture full item data per slot: id and count allow precise build tracking
        # (component rushes, stacking items like Mejai's, build order over time).
        # Stored as JSON so the CSV remains a single column but is still parseable.
        items = []
        for item in p.get("items", []):
            items.append({
                "id": item.get("itemID"),
                "name": item.get("displayName"),
                "slot": item.get("slot"),
                "count": item.get("count"),
            })

        timeline_rows.append({
            "timestamp": game_time,
            "player": p.get("summonerName"),
            "team": p.get("team"),
            "champion": p.get("championName"),
            "position": p.get("position"),

            "level": p.get("level"),
            # isDead and respawnTimer are useful for correlating deaths with objective timings
            "is_dead": p.get("isDead"),
            "respawn_timer": p.get("respawnTimer"),

            "kills": scores.get("kills"),
            "deaths": scores.get("deaths"),
            "assists": scores.get("assists"),
            "cs": scores.get("creepScore"),
            # wardScore accumulates vision score over the game
            "ward_score": scores.get("wardScore"),

            # NOTE: currentGold is only available for the active (local) player via
            # /activeplayer. It is NOT present in allPlayers. In spectator mode this
            # field will always be absent here. Kept as a placeholder for awareness.
            # To capture it for a single player: get("activeplayer").get("currentGold")

            "items": json.dumps(items)
        })


def collect_events():
    data = get("eventdata")

    if not data:
        return

    for e in data.get("Events", []):
        key = (e.get("EventName"), e.get("EventTime"), e.get("KillerName"))

        if key not in events_seen:
            events_seen.add(key)
            events.append(e)


def game_running():
    return get("gamestats") is not None


def create_match_folder():
    timestamp = datetime.now().strftime("%Y-%m-%d_%H-%M")
    folder = f"scrim_{timestamp}"

    os.makedirs(folder, exist_ok=True)

    return folder


def export_timeline(folder):
    file = os.path.join(folder, "player_timeline.csv")

    keys = [
        "timestamp",
        "player",
        "team",
        "champion",
        "position",
        "level",
        "is_dead",
        "respawn_timer",
        "kills",
        "deaths",
        "assists",
        "cs",
        "ward_score",
        "items"
    ]

    with open(file, "w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=keys)
        writer.writeheader()
        writer.writerows(timeline_rows)

    print("Saved timeline")


def export_events(folder):
    if not events:
        return

    file = os.path.join(folder, "events.csv")

    keys = set()
    for e in events:
        keys.update(e.keys())

    keys = sorted(keys)

    with open(file, "w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(
            f,
            fieldnames=keys,
            extrasaction="ignore"
        )
        writer.writeheader()
        writer.writerows(events)

    print("Saved events")


def export_metadata(folder):
    data = {
        "match": match_info,
        "players": players_metadata
    }

    file = os.path.join(folder, "metadata.json")

    with open(file, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2)

    print("Saved metadata")


def run():
    wait_for_game()

    collect_metadata()

    print("Collecting match data...")

    while game_running():
        collect_snapshot()
        collect_events()
        time.sleep(POLL_INTERVAL)

    print("Game ended")

    folder = create_match_folder()

    export_timeline(folder)
    export_events(folder)
    export_metadata(folder)

    print("Match data saved in:", folder)


if __name__ == "__main__":
    run()